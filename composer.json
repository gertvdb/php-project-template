{
    "name": "gertvdb/foo",
    "description": "foo",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "gertvdb",
            "email": "gertvandenbuijs@hotmail.com"
        }
    ],
    "require": {
        "php": "~8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpbench/phpbench": "^1.1",
        "phpstan/phpstan": "^1.9",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Gertvdb\\Foo\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gertvdb\\Foo\\": "tests",
            "Gertvdb\\Foo\\Benchmarks\\": "benchmarks"
        }
    },
    "scripts": {
        "test": [
            "vendor/bin/phpunit --testdox"
        ],
        "phpstan": [
            "vendor/bin/phpstan analyse --memory-limit=-1 --ansi"
        ]
    }
}
